{
  "expo": {
    "name": "Cabbage",
    "slug": "Passenger",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "passenger",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash2.png",
      "resizeMode": "cover",
      "backgroundColor": "#3f7564"
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ridepal.take4.passenger",
      "buildNumber": "12",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Cabbage uses the camera so you can take and upload a profile photo for your account.",
        "NSPhotoLibraryUsageDescription": "Cabbage accesses your photo library so you can choose and upload a profile photo for your account."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.ridepal.take4.passenger"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "Cabbage accesses your photo library so you can choose and upload a profile photo for your account.",
          "cameraPermission": "Cabbage uses the camera so you can take and upload a profile photo for your account."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": "https://uber.dev/"
      },
      "eas": {
        "projectId": "01b635ee-68ab-4ff3-9603-cee892648f09"
      }
    }
  }
}